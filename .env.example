# Strava API — Create an app at https://www.strava.com/settings/api
NEXT_PUBLIC_STRAVA_CLIENT_ID=
NEXT_PUBLIC_STRAVA_REDIRECT_URI=http://localhost:3000/settings

# Server-side only (used by API route, never exposed to browser)
STRAVA_CLIENT_SECRET=

# Neon PostgreSQL — Create a project at https://neon.tech
DATABASE_URL=

# AI Coach Team — Provider configuration
# Provider: "openai" or "anthropic"
AI_PROVIDER=openai
# OpenAI API key — get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Anthropic API key — get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=
# Model override (optional) — e.g., gpt-4o, gpt-4o-mini, claude-sonnet-4-5
AI_MODEL=